  "mg/L": {"canonical_unit": "mg/L", "factor": 1.0},

  "mL/min/1.73m2": {"canonical_unit": "mL/min/1.73m2", "factor": 1.0},

  "pg": {"canonical_unit": "pg", "factor": 1.0},
  "ratio": {"canonical_unit": "ratio", "factor": 1.0}
}
